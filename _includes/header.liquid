<header>
  <!-- Nav Bar -->
  <nav id="navbar" class="navbar navbar-light navbar-expand-sm {% if site.navbar_fixed %}fixed-top{% else %}sticky-top{% endif %}" role="navigation">
    <div class="container">

      {% comment %} ── Language switcher (top-left, always visible) ── {% endcomment %}
      {% assign is_pt_page = false %}
      {% if page.lang == 'pt-BR' %}{% assign is_pt_page = true %}{% endif %}

      {% comment %} Compute EN and PT URLs for current page {% endcomment %}
      {% if is_pt_page %}
        {% assign _en_href = page.permalink | remove: '/pt' %}
        {% if _en_href == '' %}{% assign _en_href = '/' %}{% endif %}
        {% assign _pt_href = page.permalink %}
      {% else %}
        {% assign _en_href = page.permalink %}
        {% assign _pt_key  = page.title | downcase %}
        {% assign _pt_data = site.data.nav_pt[_pt_key] %}
        {% assign _pt_href = _pt_data.href_pt | default: '' %}
      {% endif %}

      <div id="lang-switcher-nav" class="lang-switcher-nav">
        <a id="ls-en"
           class="ls-btn{% unless is_pt_page %} ls-active{% endunless %}"
           href="{{ _en_href | relative_url }}"
           data-save-lang="en"
           title="English"
           aria-label="Switch to English">
          <span class="ls-flag fi fi-gb"></span><span class="ls-label">EN</span>
        </a>
        {% if _pt_href != '' or is_pt_page %}
          <a id="ls-pt"
             class="ls-btn{% if is_pt_page %} ls-active{% endif %}"
             href="{{ _pt_href | relative_url }}"
             data-save-lang="pt"
             title="Português (Brasil)"
             aria-label="Mudar para Português">
            <span class="ls-flag fi fi-br"></span><span class="ls-label">PT</span>
          </a>
        {% else %}
          <span class="ls-btn ls-disabled" title="Página sem versão em português">
            <span class="ls-flag fi fi-br"></span><span class="ls-label">PT</span>
          </span>
        {% endif %}
      </div>

      {% comment %} ── Brand ── {% endcomment %}
      {% if page.permalink != '/' and page.permalink != '/pt/' %}
        <a class="navbar-brand title font-weight-lighter" href="{{ site.baseurl }}/">
          {% if site.title == 'blank' %}
            {% if site.first_name %}<span class="font-weight-bold">{{- site.first_name -}}</span>{% endif %}
            {% if site.middle_name %}{{- site.middle_name -}}{% endif %}
            {% if site.last_name %}{{- site.last_name -}}{% endif %}
          {% else %}
            {{- site.title -}}
          {% endif %}
        </a>
      {% elsif site.enable_navbar_social %}
        <div class="navbar-brand social">{% social_links %}</div>
      {% endif %}

      <!-- Navbar Toggle -->
      <button
        class="navbar-toggler collapsed ml-auto"
        type="button"
        data-toggle="collapse"
        data-target="#navbarNav"
        aria-controls="navbarNav"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <span class="sr-only">Toggle navigation</span>
        <span class="icon-bar top-bar"></span>
        <span class="icon-bar middle-bar"></span>
        <span class="icon-bar bottom-bar"></span>
      </button>

      <div class="collapse navbar-collapse text-right" id="navbarNav">
        <ul class="navbar-nav ml-auto flex-nowrap">

          {% comment %} ── About link ── {% endcomment %}
          {% for p in site.pages %}
            {% if p.permalink == '/' %}{% assign about_title_en = p.title %}{% endif %}
          {% endfor %}
          {% assign _about_pt = site.data.nav_pt['about'] %}
          <li class="nav-item {% if page.permalink == '/' or page.permalink == '/pt/' %}active{% endif %}">
            <a class="nav-link"
               href="{{ '/' | relative_url }}"
               data-en-title="{{ about_title_en }}"
               data-pt-title="{{ _about_pt.title | default: about_title_en }}"
               data-en-href="{{ '/' | relative_url }}"
               data-pt-href="{{ _about_pt.href_pt | default: '/' | relative_url }}">
              {{- about_title_en }}
              {% if page.permalink == '/' or page.permalink == '/pt/' %}
                <span class="sr-only">(current)</span>
              {% endif %}
            </a>
          </li>

          {% comment %} ── Other nav pages ── {% endcomment %}
          {% assign sorted_pages = site.pages | sort: 'nav_order' %}
          {% for p in sorted_pages %}
            {% if p.nav and p.autogen == null %}
              {% assign _pt_key  = p.title | downcase %}
              {% assign _pt_data = site.data.nav_pt[_pt_key] %}
              {% assign _pt_title = _pt_data.title | default: p.title %}
              {% assign _pt_page_href = _pt_data.href_pt | default: p.url %}

              {% if p.dropdown %}
                {% assign has_active_child = false %}
                {% for child in p.children %}
                  {% if page.title == child.title %}{% assign has_active_child = true %}{% endif %}
                {% endfor %}
                <li class="nav-item dropdown {% if page.title == p.title or has_active_child %}active{% endif %}">
                  <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown"
                     role="button" data-toggle="dropdown"
                     aria-haspopup="true" aria-expanded="false">
                    {{- p.title }}
                    {% if page.title == p.title or has_active_child %}<span class="sr-only">(current)</span>{% endif %}
                  </a>
                  <div class="dropdown-menu dropdown-menu-right" aria-labelledby="navbarDropdown">
                    {% for child in p.children %}
                      {% if child.title == 'divider' %}
                        <div class="dropdown-divider"></div>
                      {% else %}
                        <a class="dropdown-item {% if page.title == child.title %}active{% endif %}"
                           href="{% if child.permalink contains '://' %}{{ child.permalink }}{% else %}{{ child.permalink | relative_url }}{% endif %}">
                          {{- child.title -}}
                        </a>
                      {% endif %}
                    {% endfor %}
                  </div>
                </li>
              {% else %}
                {% assign parent_link = p.permalink | remove: 'index.html' %}
                {% if p.permalink contains '://' %}
                  {% assign _url = p.permalink %}
                {% elsif p.permalink contains '/blog/' %}
                  {% assign _url = '/blog/' %}
                {% else %}
                  {% assign _url = p.url %}
                {% endif %}
                <li class="nav-item {% if page.url contains parent_link %}active{% endif %}">
                  <a class="nav-link"
                     href="{{ _url | relative_url }}"
                     data-en-title="{{ p.title }}"
                     data-pt-title="{{ _pt_title }}"
                     data-en-href="{{ _url | relative_url }}"
                     data-pt-href="{{ _pt_page_href | relative_url }}">
                    {{- p.title }}
                    {% if page.url contains p.url %}<span class="sr-only">(current)</span>{% endif %}
                  </a>
                </li>
              {% endif %}
            {% endif %}
          {% endfor %}

          {% if site.search_enabled %}
            <li class="nav-item">
              <button id="search-toggle" title="Search" onclick="openSearchModal()">
                <span class="nav-link">ctrl k <i class="fa-solid fa-magnifying-glass"></i></span>
              </button>
            </li>
          {% endif %}
          {% if site.enable_darkmode %}
            <li class="toggle-container">
              <button id="light-toggle" title="Change theme">
                <i class="fa-half-sun-moon" id="light-toggle-system"></i>
                <i class="fa-solid fa-moon" id="light-toggle-dark"></i>
                <i class="fa-solid fa-sun" id="light-toggle-light"></i>
              </button>
            </li>
          {% endif %}
        </ul>
      </div>
    </div>
  </nav>
  {% if site.enable_progressbar %}
    <progress id="progress" value="0">
      <div class="progress-container"><span class="progress-bar"></span></div>
    </progress>
  {% endif %}
</header>
